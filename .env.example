# Backend Configuration
# Copy this file to .env and fill in your actual values

# Database Connection (REQUIRED)
# Get this from your Neon/PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# JWT Secret (REQUIRED)
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Initial Admin Password (REQUIRED for first setup)
# Must be strong: min 8 chars, uppercase, lowercase, number, special char
ADMIN_PASSWORD=YourStrongP@ssw0rd123!

# Frontend URL (REQUIRED for production)
# Use this to restrict CORS to your actual frontend domain
FRONTEND_URL=https://yourdomain.com

# For local development, you can use:
# FRONTEND_URL=http://localhost:5173
